# Edodwaja Web — environment variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Shared project used by both this web app and the Edodwaja mobile app.
# Find these at: https://supabase.com/dashboard/project/<ref>/settings/api

VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<your-supabase-anon-key>

# Alias accepted by the Supabase client if VITE_SUPABASE_PUBLISHABLE_KEY is not set:
# VITE_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# ── Razorpay ──────────────────────────────────────────────────────────────────
# Publishable key only — safe to expose in the browser.
# The Razorpay secret key belongs in Supabase Edge Function secrets, NOT here.
# Find this at: https://dashboard.razorpay.com/app/keys

VITE_RAZORPAY_KEY_ID=rzp_test_<your-key-id>
